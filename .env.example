# ── 後端切換（ollama 或 nvidia）────────────────────────────────────────
LLM_BACKEND=ollama

# ── Ollama（本機）───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:1b
EMBED_MODEL=nomic-embed-text

# ── NVIDIA NIM（雲端，改 LLM_BACKEND=nvidia 啟用）───────────────────────
# 申請：https://build.nvidia.com → 右上角 Get API Key
# 推薦模型：meta/llama-3.3-70b-instruct 或 google/gemma-3-12b-it
NVIDIA_API_KEY=
# LLM_MODEL=meta/llama-3.3-70b-instruct

# ── 中央氣象署開放資料平台 ──────────────────────────────────────────────
# 申請網址：https://opendata.cwa.gov.tw/
CWA_API_KEY=

# ── Google Places API ───────────────────────────────────────────────────
# 申請網址：https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# ── LLM 推論參數 ────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
